<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Common attributes defined globally to avoid duplication errors -->
    <attr name="startX" format="float" />
    <attr name="startY" format="float" />
    <attr name="endX" format="float" />
    <attr name="endY" format="float" />
    <attr name="lineColor" format="color" />
    <attr name="scaleStartX" format="float" />
    <attr name="scaleStartY" format="float" />
    <attr name="scaleEndX" format="float" />
    <attr name="scaleEndY" format="float" />
    <attr name="scaleStrokeWidth" format="float" />
    <attr name="strokeWidthPaint" format="float" />
    <attr name="joinStyle" format="enum">
        <enum name="miter" value="0" />
        <enum name="round" value="1" />
        <enum name="bevel" value="2" />
    </attr>

    <declare-styleable name="LoadCustomViewOverlay">
        <attr name="dismissible" format="boolean" />
        <attr name="closeable" format="boolean" />
    </declare-styleable>

    <declare-styleable name="LineView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="strokeWidthPaint" />
    </declare-styleable>

    <declare-styleable name="LineSegmentPathView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="strokeWidthPaint" />
    </declare-styleable>

    <declare-styleable name="TrianglePathJoinView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="strokeWidthPaint" />
        <attr name="joinStyle" />
    </declare-styleable>

    <declare-styleable name="TriangleNonClosedPathJoinView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="strokeWidthPaint" />
        <attr name="joinStyle" />
    </declare-styleable>

    <declare-styleable name="RegularPolygonView">
        <attr name="sides" format="integer" min="3" />
        <attr name="rotationDegree" format="float" />
        <attr name="scaleRadius" format="float" />
        <attr name="lineColor" />
        <attr name="scaleStrokeWidth" />
        <attr name="strokeWidthPaint" />
        <attr name="joinStyle" />
    </declare-styleable>

    <declare-styleable name="TriangleFilledPathView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="strokeWidthPaint" />
        <attr name="joinStyle" />
        <attr name="rotationDegree" />
    </declare-styleable>

    <declare-styleable name="QuadraticBezierCurveView">
