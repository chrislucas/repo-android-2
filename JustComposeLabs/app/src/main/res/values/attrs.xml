<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="LoadCustomViewOverlay">
        <attr name="dismissible" format="boolean" />
        <attr name="closeable" format="boolean" />
    </declare-styleable>

    <!--
        reference: References another resource ID (e.g., @drawable/my_image).
        color: Hexadecimal color values or color references.
        boolean: true or false.
        dimension: Size values like 16dp or 12sp.
        string: Raw text or string resource references.
        integer / float: Numerical values.
        fraction: Percentages (e.g., 50%).
        enum: A list of predefined constant values.
        flag: Similar to enum, but multiple values can be combined using the pipe (|) symbo
    -->
    <declare-styleable name="LineView">
        <attr name="startX" format="float" />
        <attr name="startY" format="float" />
        <attr name="endX" format="float" />
        <attr name="endY" format="float" />
        <attr name="lineColor" format="color" />
        <attr name="scaleStartX" format="float" />
        <attr name="scaleStartY" format="float" />
        <attr name="scaleEndX" format="float" />
        <attr name="scaleEndY" format="float" />
        <attr name="scaleStrokeWidth" format="float" />
        <attr name="strokeWidth" format="float" />
    </declare-styleable>

    <!--
        https://share.google/aimode/XJ0GwdxmhNiTatxDJ
        1. Reuso de Atributos (O "Falso" Herdar)

            Você pode reutilizar atributos já definidos globalmente ou em outros styleables sem precisar
            redefinir seu formato. Isso é útil quando sua classe filha precisa dos mesmos
            atributos da classe pai.

    -->
    <declare-styleable name="LineSegmentPathView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="strokeWidth" />
    </declare-styleable>

    <declare-styleable name="TrianglePathJoinView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="strokeWidth" />
        <attr name="joinStyle" format="enum" />
    </declare-styleable>

    <declare-styleable name="TriangleNonClosedPathJoinView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="joinStyle" />
        <attr name="strokeWidth" />

    </declare-styleable>

    <declare-styleable name="PolygonView">
        <attr name="sides" format="integer" />
        <attr name="strokeWidth" />
    </declare-styleable>

    <declare-styleable name="TriangleFilledPathView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="joinStyle" />
        <attr name="strokeWidth" />
    </declare-styleable>


    <declare-styleable name="QuadraticBezierCurveView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="joinStyle" />
        <attr name="strokeWidth" />
    </declare-styleable>

    <declare-styleable name="RationalQuadraticCurveView">
        <attr name="startX" />
        <attr name="startY" />
        <attr name="endX" />
        <attr name="endY" />
        <attr name="lineColor" />
        <attr name="scaleStartX" />
        <attr name="scaleStartY" />
        <attr name="scaleEndX" />
        <attr name="scaleEndY" />
        <attr name="scaleStrokeWidth" />
        <attr name="joinStyle" />
